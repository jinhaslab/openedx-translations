msgid "Blockquote (Ctrl+Q)"
msgstr "인용구 (Ctrl+Q)  또는  > 인용구 (Ctrl+Q)"

#: lms/static/js/Markdown.Editor.js:1458
msgid "Code Sample (Ctrl+K)"
msgstr "코드 예시 (Ctrl+K)  또는 코드 샘플 (Ctrl+K)"

