#: lms/static/js/staff_debug_actions.js:137
msgid "Successfully overrode problem score for {user}"
msgstr "{user}님의 문제 점수를 성공적으로 수정했습니다."

#: lms/static/js/staff_debug_actions.js:138
msgid "Could not override problem score for {user}."
