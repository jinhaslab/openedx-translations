msgstr ""
"문제 '<%- problem_id %>'와 학생 '<%- student_id %>'의 학습 이력을 가져오는 중 오류가 발생했습니다. "
"문제와 학생 ID가 완전하고 정확한지 확인하세요."

#: lms/static/js/instructor_dashboard/student_admin.js:287
msgid "Entrance exam attempts is being reset for student '{student_id}'."
msgstr "학생 '{student_id}'의 입시 응시 횟수가 초기화됩니다."

#: lms/static/js/instructor_dashboard/student_admin.js:295
msgid ""
"Error resetting entrance exam attempts for student '{student_id}'. Make sure"
" student identifier is correct."
msgstr "학생 '{student_id}'의 입학시험 응시 횟수 초기화에 실패했습니다. 학생 ID가 정확한지 확인해주세요."

#: lms/static/js/instructor_dashboard/student_admin.js:313
#: lms/static/js/instructor_dashboard/student_admin.js:380
msgid "Enter a student's username or email address."
msgstr "학생의 사용자 이름 또는 이메일 주소를 입력하세요."

#: lms/static/js/instructor_dashboard/student_admin.js:315
msgid ""
